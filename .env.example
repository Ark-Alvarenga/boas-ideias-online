# Application URL (e.g., http://localhost:3000 in dev, https://yourdomain.com in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentication Secret (Run `openssl rand -base64 32` to generate)
AUTH_SECRET=

# MongoDB Connection String
MONGODB_URI=

# Stripe API Keys (Get from Stripe Dashboard)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS S3 Configuration for PDF Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Platform Fee Percentage (e.g., 10 for 10%)
PLATFORM_FEE_PERCENT=10

# MAILGUN
NEXT_PUBLIC_EMAIL_USERNAME=
NEXT_PUBLIC_MAILGUN_API=
NEXT_PUBLIC_MAILGUN_DOMAIN=